# =============================================================================
# Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# =============================================================================

# --- Redis ---
# For cloud (Upstash): use rediss:// URL with TLS
# For Docker local: use redis://:YOUR_PASSWORD@redis:6379
REDIS_URL="rediss://default:YOUR_REDIS_PASSWORD@your-redis-host.upstash.io:6379"

# --- Database (PostgreSQL) ---
# For cloud (Neon): use the connection string from your dashboard
# For Docker local: use postgresql://user:pass@db:5432/dbname?schema=public
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=verify-full"


# --- App URL ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"


# --- Webhook ---
# Secret for authenticating incoming webhook requests
WEBHOOK_SECRET="generate-a-strong-random-string-here"


# --- Docker Redis (only for docker-compose deployments) ---
REDIS_PASSWORD="generate-a-strong-redis-password-here"

# --- Docker PostgreSQL (only for docker-compose deployments) ---
POSTGRES_USER="appuser"
POSTGRES_PASSWORD="generate-a-strong-db-password-here"
POSTGRES_DB="appdb"

# --- Gemini AI (optional) ---
GEMINI_API_KEY="your-gemini-api-key"

