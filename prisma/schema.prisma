generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Video {
  id          String   @id // Use Eporner video ID
  title       String
  lengthSec   Int?
  lengthMin   String?
  rate        String?
  views       Int      @default(0)
  defaultThumb Json?
  thumbs      Json?
  embedUrl    String?
  keywords    String?
  status      VideoStatus @default(ACTIVE)
  addedAt     DateTime? // from API added property

  // AI Classification & SEO
  aiScoreTrending   Float?
  aiScoreEngagement Float?
  aiScoreSpam       Float?
  aiSpamFlag        Boolean     @default(false)
  aiDescription     String?

  tags        VideoTag[]
  categories  VideoCategory[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

enum VideoStatus {
  ACTIVE
  REMOVED
  DRAFT
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  videos    VideoTag[]
}

model VideoTag {
  videoId   String
  tagId     String
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([videoId, tagId])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  videos    VideoCategory[]
}

model VideoCategory {
  videoId    String
  categoryId String
  video      Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([videoId, categoryId])
}

model SyncJob {
  id              String   @id @default(cuid())
  runStartedAt    DateTime @default(now())
  runEndedAt      DateTime?
  status          JobStatus
  itemsProcessed  Int      @default(0)
  itemsAdded      Int      @default(0)
  errorLog        String?
}

enum JobStatus {
  RUNNING
  COMPLETED
  FAILED
}

model Settings {
  key       String   @id
  value     String   // JSON stringified value
  updatedAt DateTime @updatedAt
}
