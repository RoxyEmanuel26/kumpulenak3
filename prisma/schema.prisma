generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Video {
  id          String   @id // Use Eporner video ID
  title       String
  lengthSec   Int?
  lengthMin   String?
  rate        String?
  views       Int      @default(0)
  defaultThumb Json?
  thumbs      Json?
  embedUrl    String?
  keywords    String?
  status      VideoStatus @default(ACTIVE)
  addedAt     DateTime? // from API added property

  // AI Classification & SEO
  aiScoreTrending   Float?
  aiScoreEngagement Float?
  aiScoreSpam       Float?
  aiSpamFlag        Boolean     @default(false)
  aiDescription     String?

  tags        VideoTag[]
  categories  VideoCategory[]

  broadcasts  BroadcastLog[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

enum VideoStatus {
  ACTIVE
  REMOVED
  DRAFT
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  videos    VideoTag[]
}

model VideoTag {
  videoId   String
  tagId     String
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  tag       Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([videoId, tagId])
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  videos    VideoCategory[]
}

model VideoCategory {
  videoId    String
  categoryId String
  video      Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([videoId, categoryId])
}

model SyncJob {
  id              String   @id @default(cuid())
  runStartedAt    DateTime @default(now())
  runEndedAt      DateTime?
  status          JobStatus
  itemsProcessed  Int      @default(0)
  itemsAdded      Int      @default(0)
  errorLog        String?
}

enum JobStatus {
  RUNNING
  COMPLETED
  FAILED
}

model TelegramChannel {
  id             String   @id // Telegram Chat ID
  name           String
  isActive       Boolean  @default(true)
  template       String?  // Custom message template
  routingRules   Json?    // Optional tag/category filters
  
  botId          String?  // Link to custom bot, if null use default bot
  bot            TelegramBot? @relation(fields: [botId], references: [id], onDelete: SetNull)

  broadcasts     BroadcastLog[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TelegramBot {
  id        String            @id @default(cuid())
  token     String            @unique
  name      String
  username  String?
  isActive  Boolean           @default(true)
  channels  TelegramChannel[]
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
}

model BroadcastLog {
  id             String   @id @default(cuid())
  videoId        String
  channelId      String
  status         BroadcastStatus @default(PENDING)
  retryCount     Int      @default(0)
  errorMessage   String?
  messageId      String?  // The Telegram message ID if successful
  
  video          Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  channel        TelegramChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  clicks         TelegramClick[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([videoId, channelId]) // Deduplication
  @@index([status])
}

model TelegramClick {
  id             String       @id @default(cuid())
  broadcastLogId String
  clickedAt      DateTime     @default(now())
  broadcastLog   BroadcastLog @relation(fields: [broadcastLogId], references: [id], onDelete: Cascade)
  
  @@index([clickedAt])
}

enum BroadcastStatus {
  PENDING
  SENT
  FAILED
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Hashed
  name      String?
  auditLogs AuditLog[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Settings {
  key       String   @id
  value     String   // JSON stringified value
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String    @id @default(cuid())
  adminId   String
  admin     AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  action    String
  details   Json?
  createdAt DateTime  @default(now())

  @@index([adminId])
}
